# Next.js 主基座镜像（多阶段构建）
FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9 --activate

ARG PUBLIC_ORIGIN=http://localhost
ARG NEXT_PUBLIC_API_BASE
ARG NEXT_PUBLIC_MICRO_WEB
ARG NEXT_PUBLIC_MICRO_ADMIN

ENV NEXT_PUBLIC_API_BASE=${NEXT_PUBLIC_API_BASE:-${PUBLIC_ORIGIN}/api}
ENV NEXT_PUBLIC_MICRO_WEB=${NEXT_PUBLIC_MICRO_WEB:-${PUBLIC_ORIGIN}/micro/web/}
ENV NEXT_PUBLIC_MICRO_ADMIN=${NEXT_PUBLIC_MICRO_ADMIN:-${PUBLIC_ORIGIN}/micro/admin/}

WORKDIR /app/next-host

COPY next-host/package.json next-host/pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile 2>/dev/null || pnpm install

# globals.scss / tailwind.config 引用 ../qiankun-subapps/_shared
COPY qiankun-subapps/_shared ../qiankun-subapps/_shared
# _shared 独立 package.json（dayjs 等），Docker 内须单独安装否则 webpack 无法解析
RUN cd ../qiankun-subapps/_shared && pnpm install --frozen-lockfile 2>/dev/null || pnpm install
COPY next-host/ ./

RUN pnpm run build

# ---------- 生产运行阶段 ----------
FROM node:20-alpine AS runner
RUN corepack enable && corepack prepare pnpm@9 --activate
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

COPY --from=base /app/next-host/package.json ./
COPY --from=base /app/next-host/node_modules ./node_modules
COPY --from=base /app/next-host/.next ./.next
COPY --from=base /app/next-host/public ./public

EXPOSE 3000

CMD ["pnpm", "start"]
