# SQLite 数据库路径
DATABASE_URL="file:./dev.db"

# JWT 密钥（生产环境务必修改）
JWT_SECRET=personal-site-dev-secret

# 管理员初始密码（seed 时使用）
ADMIN_PASSWORD=admin123

# CORS 允许的前台域名（生产部署时设置）
# CORS_ORIGIN=http://localhost

# ---------- AI 小助手（OpenAI 兼容 API）----------
# 也可在管理后台「AI小助手管理 → 数据配置管理」页面在线配置（DB 优先于 env）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LanceDB 向量库本地目录
LANCE_DB_PATH=./data/lancedb

# 文档分块参数
AI_CHUNK_SIZE=800
AI_CHUNK_OVERLAP=100

# Embedding 单次请求 batch 大小（通义千问 dashscope 上限 10，勿超过）
# AI_EMBEDDING_BATCH_SIZE=10

# 高德 Web 服务 Key（便民逆地理 /api/geocode/reverse）
# 必须在控制台创建平台类型为「Web服务」的 Key，并勾选「逆地理编码」服务
# 与前端 VITE_AMAP_KEY_WEB（JS API 2.0）不是同一个 Key，不能混用
AMAP_WEB_SERVICE_KEY=
