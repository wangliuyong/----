generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  summary     String?
  content     String
  category    String?
  tags        String?
  slug        String?  @unique
  publishedAt DateTime @default(now())
}

model Project {
  id         Int     @id @default(autoincrement())
  name       String
  desc       String
  techStack  String?
  githubUrl  String?
  previewUrl String?
}

model Message {
  id        Int      @id @default(autoincrement())
  nickname  String
  contact   String?
  content   String
  createdAt DateTime @default(now())
}

model Link {
  id          Int     @id @default(autoincrement())
  name        String
  url         String
  description String?
  avatar      String?
  sort        Int     @default(0)
}
