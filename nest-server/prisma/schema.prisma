generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  summary     String?
  content     String
  category    String?
  tags        String?
  slug        String?  @unique
  publishedAt DateTime @default(now())
}

model Project {
  id         Int     @id @default(autoincrement())
  name       String
  desc       String
  techStack  String?
  githubUrl  String?
  previewUrl String?
}

model Message {
  id        Int      @id @default(autoincrement())
  nickname  String
  contact   String?
  content   String
  createdAt DateTime @default(now())
}

model Link {
  id          Int     @id @default(autoincrement())
  name        String
  url         String
  description String?
  avatar      String?
  sort        Int     @default(0)
}

/** 管理后台账号 */
model AdminUser {
  id        Int             @id @default(autoincrement())
  username  String          @unique
  password  String
  nickname  String?
  status    Int             @default(1)
  createdAt DateTime        @default(now())
  roles     AdminUserRole[]
}

/** 后台菜单/模块树 */
model AdminModule {
  id          Int               @id @default(autoincrement())
  parentId    Int?
  parent      AdminModule?      @relation("ModuleTree", fields: [parentId], references: [id])
  children    AdminModule[]     @relation("ModuleTree")
  name        String
  code        String            @unique
  type        String
  path        String?
  icon        String?
  component   String?
  sort        Int               @default(0)
  status      Int               @default(1)
  permissions AdminPermission[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

/** 菜单下权限点（菜单可见 / 按钮 / API） */
model AdminPermission {
  id       Int                   @id @default(autoincrement())
  moduleId Int
  module   AdminModule           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  code     String                @unique
  name     String
  type     String
  sort     Int                   @default(0)
  roles    AdminRolePermission[]
}

/** 后台角色 */
model AdminRole {
  id          Int                   @id @default(autoincrement())
  name        String
  code        String                @unique
  description String?
  isSuper     Boolean               @default(false)
  status      Int                   @default(1)
  permissions AdminRolePermission[]
  users       AdminUserRole[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model AdminRolePermission {
  roleId       Int
  permissionId Int
  role         AdminRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   AdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AdminUserRole {
  userId Int
  roleId Int
  user   AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

/** 站点全局配置（单行，id 固定为 1） */
model SiteConfig {
  id          Int    @id @default(1)
  siteName    String @default("王刘永的博客")
  githubUrl   String @default("https://github.com/wly-dev")
  email       String @default("hello@wly.dev")
  navJson     String @default("[]")
  aboutJson   String @default("{}")
  contactJson String @default("{}")
}

/** 管理后台操作审计日志 */
model AdminAuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  username  String?
  action    String
  module    String?
  targetId  String?
  detail    String?
  ip        String?
  createdAt DateTime @default(now())
}

/** 应用运行日志（供 AI 向量化与后台排查） */
model AppLog {
  id        Int      @id @default(autoincrement())
  level     String
  message   String
  context   String?
  stack     String?
  createdAt DateTime @default(now())
}

/** AI 数据源同步记录 */
model AiSyncRecord {
  id         Int       @id @default(autoincrement())
  sources    String
  status     String
  chunkCount Int       @default(0)
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}

/** AI 小助手配置（单行，id 固定为 1；优先于环境变量） */
model AiConfig {
  id                   Int      @id @default(1)
  openaiApiKey         String?
  openaiBaseUrl        String   @default("https://api.openai.com/v1")
  openaiChatModel      String?
  openaiEmbeddingModel String?
  /** 向量维度（通义 text-embedding-v3 默认 1024，OpenAI 默认 1536） */
  embeddingDimensions  Int?
  updatedAt            DateTime @updatedAt
}

/** AI 用户问答会话（前台 sessionId 与 LangGraph thread_id 一致） */
model AiChatSession {
  id           String          @id
  messageCount Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  messages     AiChatMessage[]
}

/** AI 用户问答消息（user / assistant 一问一答持久化，供管理端审计） */
model AiChatMessage {
  id        Int           @id @default(autoincrement())
  sessionId String
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  /** user | assistant */
  role      String
  content   String
  /** 助手回复失败时的错误信息 */
  error     String?
  createdAt DateTime      @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

/** 前台页面访问记录（供管理端首页图表统计） */
model SitePageView {
  id        Int      @id @default(autoincrement())
  path      String
  referrer  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}
