generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  summary     String?
  content     String
  category    String?
  tags        String?
  slug        String?  @unique
  publishedAt DateTime @default(now())
}

model Project {
  id         Int     @id @default(autoincrement())
  name       String
  desc       String
  techStack  String?
  githubUrl  String?
  previewUrl String?
}

model Message {
  id        Int      @id @default(autoincrement())
  nickname  String
  contact   String?
  content   String
  createdAt DateTime @default(now())
}

model Link {
  id          Int     @id @default(autoincrement())
  name        String
  url         String
  description String?
  avatar      String?
  sort        Int     @default(0)
}

/** 管理后台账号 */
model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

/** 站点全局配置（单行，id 固定为 1） */
model SiteConfig {
  id          Int    @id @default(1)
  siteName    String @default("王刘永的博客")
  githubUrl   String @default("https://github.com/wly-dev")
  email       String @default("hello@wly.dev")
  navJson     String @default("[]")
  aboutJson   String @default("{}")
  contactJson String @default("{}")
}
