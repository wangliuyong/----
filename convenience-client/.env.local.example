# 复制为 .env.local 并填入真实 Key（.env.local 已被 gitignore，不会提交）
# 控制台：https://console.amap.com/dev/key/app

# Web 端 JS API（H5 地图 <map> 组件展示，需配置域名白名单）
VITE_AMAP_KEY_WEB=

# Web 端安全密钥（JS API 2.0，与 VITE_AMAP_KEY_WEB 配对）
VITE_AMAP_SECURITY_CODE=

# App 端 SDK Key（云打包 / 离线打包前注入 manifest）
VITE_AMAP_KEY_ANDROID=
VITE_AMAP_KEY_IOS=

# 微信小程序 Key（可选，逆地理已走后端 Web 服务）
VITE_AMAP_KEY_WEIXIN=

# 逆地理编码由后端代理，本地 nest-server/.env 配置：
# AMAP_WEB_SERVICE_KEY=
